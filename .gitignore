# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/

# ----- IDE / OS -----
.vscode/
.idea/
.cursor/
.DS_Store
Thumbs.db

# ----- Scratch / one-off helpers -----
# Disposable utilities like _peek_hh.py, _reconstruct_lineups.py, _show_top.py.
# Top-level files starting with an underscore are treated as scratch and
# excluded from version control.
/_*.py

# ----- Data + caches -----
# Cached Statcast pulls are organized into data/<year>/ subfolders.
# Prior-season folders are immutable and committed to the repo so codespaces
# start warm. The current-season folder rolls forward daily and is ignored.
# Update this line at the start of each new MLB season.
data/2026/

# pybaseball http cache
.pybaseball/

# ----- Generated reports -----
# All matchup/lineup reports go to reports/<YYYY-MM-DD>/ and are regenerable.
reports/

# ----- Per-run logs -----
# Each script run tees stdout/stderr to logs/<timestamp>/<script>.log via
# log_setup.py. Keep them out of version control.
logs/

# Per-player summary scratch outputs (regenerable)
*_summary.md
*_pitcher_summary.md

# Daily lineup pulls from fetch_lineups.py
matchups_*.csv

# Misc
*.log
kyle_bradish_vs_yankees_hitters.txt
